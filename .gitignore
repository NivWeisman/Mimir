# Rust build artifacts
/target
**/*.rs.bk
Cargo.lock.bak

# C++ slang sidecar build output (out-of-source CMake build)
slang-sidecar/build/
slang-sidecar/build.log

# Downloaded Verible formatter binary (fetched by `make verible`)
tools/verible/

# VS Code extension build output
editors/vscode/node_modules/
editors/vscode/out/
editors/vscode/*.vsix

# Editor / OS junk
.DS_Store
*.swp
.idea/
.vscode/

# Claude Code per-user state (settings.local.json is machine-specific)
.claude/settings.local.json
current-plan.md

# Python bytecode cache from the integration test suite (tests/)
__pycache__/
*.pyc

# Example workspace repos are locally cloned external git repos; gitignore the
# whole directory.  Users follow README "Setup examples" to clone them and the
# .mimir.toml config is written by `make setup-examples` (or copied manually).
examples/
