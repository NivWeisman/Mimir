{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SystemVerilog",
  "scopeName": "source.systemverilog",
  "fileTypes": ["sv", "svh", "v", "vh"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#macro-call" },
    { "include": "#system-task" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.systemverilog",
          "match": "//.*$"
        },
        {
          "name": "comment.block.systemverilog",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.systemverilog",
          "match": "`(ifdef|ifndef|else|elsif|endif|define|undef|undefineall|include|line|resetall|timescale|default_nettype|nounconnected_drive|unconnected_drive|celldefine|endcelldefine|pragma|begin_keywords|end_keywords|__FILE__|__LINE__)\\b",
          "captures": {
            "0": { "name": "keyword.control.directive.systemverilog" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.systemverilog",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.systemverilog",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sized.systemverilog",
          "match": "\\b\\d+'[sS]?[bBoOdDhH][0-9a-fA-FxXzZ_?]+"
        },
        {
          "name": "constant.numeric.unsized.systemverilog",
          "match": "'[sS]?[bBoOdDhH][0-9a-fA-FxXzZ_?]+"
        },
        {
          "name": "constant.numeric.real.systemverilog",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.systemverilog",
          "match": "\\b\\d[\\d_]*\\b"
        },
        {
          "name": "constant.language.systemverilog",
          "match": "\\b('0|'1|'x|'X|'z|'Z)\\b"
        }
      ]
    },
    "attributes": {
      "name": "meta.attribute.systemverilog",
      "begin": "\\(\\*",
      "end": "\\*\\)",
      "patterns": [{ "include": "#strings" }]
    },
    "macro-call": {
      "name": "entity.name.function.macro.systemverilog",
      "match": "`[A-Za-z_][A-Za-z0-9_]*"
    },
    "system-task": {
      "name": "support.function.system.systemverilog",
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.systemverilog",
          "match": "\\b(if|else|case|casex|casez|endcase|default|for|foreach|while|do|repeat|forever|break|continue|return|begin|end|fork|join|join_any|join_none|disable|wait|wait_order|assert|assume|cover|expect|property|endproperty|sequence|endsequence|first_match|throughout|within|intersect|inside|dist|bind|with|matches|tagged|priority|unique|unique0)\\b"
        },
        {
          "name": "keyword.declaration.systemverilog",
          "match": "\\b(module|endmodule|interface|endinterface|program|endprogram|package|endpackage|class|endclass|extends|implements|virtual|pure|extern|local|protected|static|automatic|const|rand|randc|constraint|covergroup|endgroup|coverpoint|cross|bins|illegal_bins|ignore_bins|wildcard|binsof|function|endfunction|task|endtask|generate|endgenerate|genvar|typedef|enum|struct|union|packed|tagged|chandle|event|nettype|specify|endspecify|specparam|primitive|endprimitive|table|endtable|config|endconfig|design|cell|liblist|use|instance|property|endproperty|sequence|endsequence|checker|endchecker|clocking|endclocking|modport|import|export|let|nettype|this|super|new|null|void)\\b"
        },
        {
          "name": "keyword.other.systemverilog",
          "match": "\\b(initial|always|always_comb|always_ff|always_latch|final|assign|deassign|force|release|posedge|negedge|edge|iff|input|output|inout|ref|var|parameter|localparam|defparam|automatic|context|pure|signed|unsigned|highz0|highz1|strong0|strong1|weak0|weak1|pull0|pull1|supply0|supply1|small|medium|large|scalared|vectored)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.systemverilog",
          "match": "\\b(logic|bit|byte|shortint|int|longint|integer|time|reg|wire|tri|tri0|tri1|triand|trior|trireg|wand|wor|uwire|real|shortreal|realtime|string|chandle|event|void|untyped)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.systemverilog",
          "match": "(<<<|>>>|<<|>>|<=|>=|==|!=|===|!==|==\\?|!=\\?|&&|\\|\\||->|<->|::|\\+:|-:|\\*\\*|[+\\-*/%&|^~!?:=<>])"
        }
      ]
    }
  }
}
